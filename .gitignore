# ─── 环境变量（含 API Key，绝不上传）─────────────────
.env
.env.local
.env.*.local

# ─── 密钥和证书 ──────────────────────────────────────
*.key
*.pem
*.crt
*.p12

# ─── 日志文件 ────────────────────────────────────────
logger/
logs/
*.log

# ─── 向量数据库（Chroma 生成，重建即可恢复）───────────
data/db/

# ─── 用户数据文件（不提交原始文档，仅保留示例）────────
/data/*.txt
/data/*.csv
/data/*.pdf
/data/*.xlsx
/data/**/*.txt
/data/**/*.csv
/data/**/*.pdf

# 保留目录结构
!data/
!data/inputs/
!data/outputs/

# ─── 模型文件（大文件不提交）──────────────────────────
models/
*.pkl
*.h5
*.pb
*.pt
*.pth

# ─── Python 缓存 ─────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ─── Gradio 热重载缓存 ───────────────────────────────
.gradio/

# ─── IDE / 编辑器配置 ────────────────────────────────
.vscode/
.idea/
*.iml
.DS_Store

# ─── 测试 & 覆盖率 ───────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── 临时文件 ────────────────────────────────────────
*.tmp
*.swp
*.cache
*.swo

# ─── 数据库文件（本地开发库）─────────────────────────
*.db
*.sqlite
*.sqlite3

# ─── 压缩包 ──────────────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z